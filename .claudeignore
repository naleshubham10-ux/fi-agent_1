# ── Large binary / generated files — skip entirely ───────────────────────────
server/.venv/
web/node_modules/
web/dist/
android/.gradle/
android/build/
android/app/build/

# ── Case data & recordings (can be huge) ─────────────────────────────────────
fig/
storage/
*.webm
*.mp4
*.ogg

# ── Generated PDFs (binary, not useful for code analysis) ────────────────────
*.pdf
server/docs/

# ── Secrets ───────────────────────────────────────────────────────────────────
server/.env
*.pem
*.key
*.jks
*.keystore
credentials.json
service-account*.json

# ── Compiled / cache ──────────────────────────────────────────────────────────
**/__pycache__/
**/*.pyc
**/*.pyo
*.tsbuildinfo
.eggs/

# ── OS noise ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Compressed archives ───────────────────────────────────────────────────────
*.zip
*.tar.gz
server.zip
